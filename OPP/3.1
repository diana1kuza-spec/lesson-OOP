import random

class Monster:
    def __init__(self, name, hp, dmg):
        self.name = name
        self.hp = hp
        self.dmg = dmg

    def take_damage(self, damage):
        self.hp -= damage
        print(f"{self.name} получил {damage} урона. У него {self.hp} хп.")

    def attack_hunter(self, hunter):
        hunter.hp -= self.dmg
        print(f"{self.name} атакует охотника на {self.dmg} урона. У охотника {hunter.hp} хп.")


class Zombie(Monster):
    def __init__(self, name):
        super().__init__(name=name, hp=120, dmg=10)

    def take_damage(self, damage):
        self.hp -= damage
        print(f"Зомби теряет конечность! Получено: {damage}. HP: {self.hp}")


class Vampire(Monster):
    def __init__(self, name):
        super().__init__(name=name, hp=80, dmg=15)

    def take_damage(self, damage):
        absorbed = 5
        actual_damage = damage - absorbed
        if actual_damage < 0:
            actual_damage = 0
        self.hp -= actual_damage
        print(f"{self.name} поглощает {absorbed} урона! Получено: {actual_damage}. HP: {self.hp}")


class Ghost(Monster):
    def __init__(self, name):
        super().__init__(name=name, hp=60, dmg=20)

    def take_damage(self, damage):
        if random.random() < 0.3:
            print(f"{self.name} уклоняется от удара! HP: {self.hp}")
            return
        self.hp -= damage
        print(f"{self.name} получил {damage} урона. HP: {self.hp}")


class Werewolf(Monster):
    def __init__(self, name):
        super().__init__(name=name, hp=100, dmg=25)
        self.transformed = False

    def take_damage(self, damage):
        self.hp -= damage
        print(f"{self.name} получил {damage} урона. HP: {self.hp}")
        if self.hp < 50 and not self.transformed:
            self.transformed = True
            print(f"{self.name} трансформируется! Сила увеличивается!")


# ========== ОРУЖИЕ ==========
class Weapon:
    def __init__(self, name):
        self.name = name

    def use(self, monster):
        pass


class SilverSword(Weapon):
    def __init__(self):
        super().__init__("Серебряный меч")

    def use(self, monster):
        damage = 30
        print(f"⚔️ Охотник использует {self.name} против {monster.name}! Урон: {damage}")
        monster.take_damage(damage)


class HolyWater(Weapon):
    def __init__(self):
        super().__init__("Святая вода")

    def use(self, monster):
        damage = 20
        print(f"💧 Охотник использует {self.name} против {monster.name}! Урон: {damage}")
        monster.take_damage(damage)


class CrossbowBolt(Weapon):
    def __init__(self):
        super().__init__("Арбалет с болтом")

    def use(self, monster):
        damage = 25
        print(f"🏹 Охотник использует {self.name} против {monster.name}! Урон: {damage}")
        monster.take_damage(damage)


# ========== ПРОВЕРКА (СТРОГО ПО ПРИМЕРУ) ==========
weapons = [SilverSword(), HolyWater(), CrossbowBolt()]
zombie = Zombie("Зомби")

for w in weapons:
    w.use(zombie)

# Полиморфизм: один цикл три разных удара!
