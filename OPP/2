class Monster:
    def __init__(self, name, hp, dmg):
        self.__name = name
        self.__hp = hp
        self.__dmg = dmg

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def get_dmg(self):
        return self.__dmg

    def set_hp(self, value):
        if value < 0:
            self.__hp = 0
        else:
            self.__hp = value

    def is_alive(self):
        return self.__hp > 0

    def show_status(self):
        print(f"Name: {self.__name} HP: {self.__hp}")

    def take_damage(self, damage):
        self.set_hp(self.__hp - damage)
        print(f"{self.__name} получил {damage} урона. HP {self.__hp}")

    def attack_hunter(self, hunter):
        print(f"{self.__name} атакует охотника на {self.__dmg} урона!")
        hunter.take_damage(self.__dmg)

class Zombie(Monster):
    def __init__(self, name):
        super().__init__(name, 120, 10)

    def take_damage(self, damage):
        self.set_hp(self.get_hp() - damage)
        print(f"ЗОмби теряет конечность! Получено: {damage}. HP {self.get_hp()}")

class Vampire(Monster):
    def __init__(self, name):
        super().__init__(name, 80, 15)

        def take_damage(self, damage):
            absorbed = 5
            actual_damage = damage - absorbed
            if actual_damage <= 0:
                actual_damage = 0
            self.set_hp(self.__hp - actual_damage)
            print(f"{self.get_name()} поглощает {absorbed} урона! Получено: {actual_damage}. Hp {self.get_hp()}")

import random

class Ghost(Monster):
    def __init__(self, name):
        super().__init__(name, 60, 20)

        def take_damage(self, damage):
            if random.random() < 0.3:
                print(f"{self.get_name()} уклоняется от удара! HP {self.get_hp()}")
                return
            self.set_hp(self.get_hp() - damage)
            print(f"{self.get_name()} получил {damage} урона. HP {self.get_hp()}")

class Werewolf(Monster):
    def __init__(self, name):
        super().__init__(name, 100, 25)
        self.__transformed = False

        def take_damage(self, damage):
            self.set_hp(self.get_hp() - damage)
            print(f"{self.get_name()} получил {damage} урона. HP {self.get_hp()}")

            if self.get_hp() < 50 and not self.__transformed:
                self.__transformed = True
                print(f"{self.get_name()} трансформируется в оборотня! Сила увеличивается!")

v = Vampire("Дракула")
v.take_damage(30)
# Дракула поглощает 5 урона! Получено: 25. HP: 55

z = Zombie("Зомби")
z.take_damage(30)
# Зомби теряет конечность! Получено: 30. HP: 90
