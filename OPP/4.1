import random
import time

# ========== MONSTER И НАСЛЕДНИКИ ==========
class Monster:
    def __init__(self, name, hp, dmg):
        self.name = name
        self.hp = hp
        self.dmg = dmg

    def take_damage(self, damage):
        self.hp -= damage
        if self.hp < 0:
            self.hp = 0
        print(f"💥 {self.name} получил {damage} урона. У него {self.hp} ❤️")

    def attack_hunter(self, hunter):
        hunter.set_hp(hunter.get_hp() - self.dmg)
        print(f"🗡️ {self.name} атакует охотника на {self.dmg} урона! У охотника {hunter.get_hp()} ❤️")

    def is_alive(self):
        return self.hp > 0


class Zombie(Monster):
    def __init__(self, name):
        super().__init__(name, 120, 10)

    def take_damage(self, damage):
        self.hp -= damage
        if self.hp < 0:
            self.hp = 0
        print(f"🧟 Зомби теряет конечность! Получено: {damage}. HP: {self.hp}")


class Vampire(Monster):
    def __init__(self, name):
        super().__init__(name, 80, 15)

    def take_damage(self, damage):
        absorbed = 5
        actual_damage = damage - absorbed
        if actual_damage < 0:
            actual_damage = 0
        self.hp -= actual_damage
        if self.hp < 0:
            self.hp = 0
        print(f"🧛 {self.name} поглощает {absorbed} урона! Получено: {actual_damage}. HP: {self.hp}")


class Ghost(Monster):
    def __init__(self, name):
        super().__init__(name, 60, 20)

    def take_damage(self, damage):
        if random.random() < 0.3:
            print(f"👻 {self.name} уклоняется от удара! HP: {self.hp}")
            return
        self.hp -= damage
        if self.hp < 0:
            self.hp = 0
        print(f"👻 {self.name} потерял {damage} Хп. Сейчас у него {self.hp} Хп.")


class Werewolf(Monster):
    def __init__(self, name):
        super().__init__(name, 100, 25)
        self.transformed = False

    def take_damage(self, damage):
        self.hp -= damage
        if self.hp < 0:
            self.hp = 0
        print(f"🐺 {self.name} получил {damage} урона. HP: {self.hp}")
        if self.hp < 50 and not self.transformed:
            self.transformed = True
            print(f"🐺🔴 {self.name} ТРАНСФОРМИРУЕТСЯ! Сила увеличивается!")


# ========== ОРУЖИЕ ==========
class Weapon:
    def __init__(self, name, dmg):
        self.name = name
        self.dmg = dmg

    def use(self, monster):
        monster.take_damage(self.dmg)


class SilverWord(Weapon):
    def __init__(self):
        super().__init__("⚔️ Серебряный меч", 30)


class HolyWater(Weapon):
    def __init__(self):
        super().__init__("💧 Святая вода", 20)


class CrossbowBolt(Weapon):
    def __init__(self):
        super().__init__("🏹 Арбалет с болтом", 25)


# ========== ОХОТНИК ==========
class Hunter:
    def __init__(self, name):
        self.__name = name
        self.__hp = 100
        self.__weapons = []

    def get_name(self):
        return self.__name

    def get_hp(self):
        return self.__hp

    def set_hp(self, value):
        if value < 0:
            self.__hp = 0
        else:
            self.__hp = value

    def is_alive(self):
        return self.__hp > 0

    def add_weapon(self, weapon):
        self.__weapons.append(weapon)
        print(f"🎒 Охотник {self.__name} взял {weapon.name}!")

    def show_inventory(self):
        if not self.__weapons:
            print("📭 Инвентарь пуст!")
            return
        print(f"\n🎒 ИНВЕНТАРЬ охотника {self.__name}:")
        for i, weapon in enumerate(self.__weapons, start=1):
            print(f"   {i}. {weapon.name} (урон: {weapon.dmg})")

    def attack(self, weapon_index, monster):
        if weapon_index < 1 or weapon_index > len(self.__weapons):
            print("❌ Неверный номер оружия!")
            return False
        weapon = self.__weapons[weapon_index - 1]
        print(f"\n🏹 {self.__name} атакует {monster.name} с помощью {weapon.name}!")
        weapon.use(monster)
        return not monster.is_alive()  # True если монстр мёртв


# ========== БОЙНЯ ==========
def battle():
    print("\n" + "=" * 60)
    print("⚔️⚔️⚔️ НАЧИНАЕТСЯ БОЙНЯ! ⚔️⚔️⚔️")
    print("=" * 60)

    # Создаём охотника
    hunter = Hunter("Ван Хельсинг")

    # Создаём оружие
    weapons = [SilverWord(), HolyWater(), CrossbowBolt()]
    for w in weapons:
        hunter.add_weapon(w)

    hunter.show_inventory()

    # Создаём армию монстров
    monsters = [
        Zombie("Зомби-1"),
        Zombie("Зомби-2"),
        Vampire("Дракула"),
        Ghost("Каспер"),
        Werewolf("Вервульф")
    ]

    print("\n" + "=" * 60)
    print("👾 АРМИЯ ТЬМЫ: 👾")
    for m in monsters:
        print(f"   - {m.name} (❤️ {m.hp}, 🗡️ {m.dmg})")
    print("=" * 60)

    current_weapon = 1  # Начинаем с первого оружия

    # Бой с каждым монстром по очереди
    for monster in monsters:
        print("\n" + "=" * 60)
        print(f"🔥 НОВЫЙ ПРОТИВНИК: {monster.name} (❤️ {monster.hp}) 🔥")
        print("=" * 60)

        while monster.is_alive() and hunter.is_alive():
            # Ход охотника
            print(f"\n💪 У охотника {hunter.get_hp()} ❤️")
            hunter.show_inventory()

            # Выбор оружия (можно менять в бою)
            print(f"\n🔫 Текущее оружие: {weapons[current_weapon-1].name}")
            choice = input("Введи номер оружия (1-3) или Enter чтобы атаковать: ")

            if choice.strip():
                try:
                    current_weapon = int(choice)
                    if current_weapon < 1 or current_weapon > 3:
                        current_weapon = 1
                        print("⚠️ Неверный номер, используем первое оружие!")
                except:
                    current_weapon = 1

            # Атака охотника
            monster_is_dead = hunter.attack(current_weapon, monster)

            if monster_is_dead:
                print(f"\n✅ {monster.name} ПОВЕРЖЕН! ✅")
                break

            # Ход монстра (если он ещё жив)
            if monster.is_alive():
                time.sleep(0.5)
                monster.attack_hunter(hunter)

                if not hunter.is_alive():
                    print(f"\n💀 ОХОТНИК {hunter.get_name()} ПОГИБ В БОЮ! 💀")
                    break
            else:
                print(f"\n✅ {monster.name} ПОВЕРЖЕН! ✅")
                break

        if not hunter.is_alive():
            break

        print(f"\n🎉 Охотник победил {monster.name}! Осталось ❤️: {hunter.get_hp()}")

    # Итог битвы
    print("\n" + "=" * 60)
    if hunter.is_alive():
        print("🏆🏆🏆 ПОБЕДА! ОХОТНИК ВАН ХЕЛЬСИНГ УНИЧТОЖИЛ ВСЕХ МОНСТРОВ! 🏆🏆🏆")
        print(f"Осталось здоровья: {hunter.get_hp()} ❤️")
    else:
        print("💀💀💀 ОХОТНИК ПОГИБ... ТЬМА ПОБЕДИЛА... 💀💀💀")
    print("=" * 60)


# ========== ЗАПУСК БОЙНИ ==========
if __name__ == "__main__":
    battle()
